# Blockchain environment — never commit real private keys!

# ── RPC URLs ──────────────────────────────────────────────────────────────────
# Get free endpoints from: https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Deployer wallet ────────────────────────────────────────────────────────────
# Export from MetaMask: Account → Export Private Key
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Block explorer API keys (for contract verification) ────────────────────────
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
# https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ── Gas reporter ───────────────────────────────────────────────────────────────
REPORT_GAS=false
# https://coinmarketcap.com/api/
CMC_API_KEY=YOUR_CMC_API_KEY
