# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it is blocked by .gitignore.

# Server port
PORT=5000

# MongoDB connection string
# Get yours from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_a_long_random_secret_string

# Backend URL
# Local development:
BACKEND_URL=http://localhost:5000
# After deploying to Render, replace with your Render URL:
# BACKEND_URL=https://your-app-name.onrender.com
